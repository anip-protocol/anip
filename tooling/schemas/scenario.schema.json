{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anip.dev/schemas/scenario.schema.json",
  "title": "ANIP Scenario",
  "description": "Structured execution scenario input for ANIP Execution Scenario Validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scenario"
  ],
  "properties": {
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "category",
        "narrative",
        "context",
        "expected_behavior",
        "expected_anip_support"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$",
          "minLength": 3,
          "maxLength": 128
        },
        "category": {
          "type": "string",
          "enum": [
            "safety",
            "recovery",
            "orchestration",
            "cross_service",
            "observability"
          ]
        },
        "narrative": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "context": {
          "type": "object",
          "description": "Scenario-specific execution context. Kept flexible so domain packs can evolve quickly.",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/contextValue"
          }
        },
        "expected_behavior": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "expected_anip_support": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        }
      }
    }
  },
  "$defs": {
    "contextValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contextValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/contextValue"
          }
        }
      ]
    }
  }
}
