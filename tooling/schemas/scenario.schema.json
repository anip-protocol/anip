{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anip.dev/schemas/scenario.schema.json",
  "title": "ANIP Scenario",
  "description": "Structured execution scenario input for ANIP Execution Scenario Validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scenario"
  ],
  "properties": {
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "category",
        "narrative",
        "context",
        "expected_behavior",
        "expected_anip_support"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$",
          "minLength": 3,
          "maxLength": 128
        },
        "category": {
          "type": "string",
          "enum": [
            "safety",
            "recovery",
            "orchestration",
            "cross_service",
            "observability"
          ]
        },
        "narrative": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "context": {
          "type": "object",
          "description": "Scenario-specific execution context. Kept flexible so domain packs can evolve quickly.",
          "additionalProperties": {
            "$ref": "#/$defs/contextValue"
          }
        },
        "context_not_applicable": {
          "type": "boolean"
        },
        "participating_services": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        },
        "orchestration_steps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "derived_from": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/contextValue"
          }
        },
        "additional_context": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/additionalContextEntry"
          }
        },
        "expected_behavior": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "expected_anip_support": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        }
      },
      "allOf": [
        {
          "anyOf": [
            {
              "properties": {
                "context_not_applicable": {
                  "const": true
                }
              },
              "required": [
                "context_not_applicable"
              ]
            },
            {
              "properties": {
                "context": {
                  "minProperties": 1
                }
              }
            }
          ]
        }
      ]
    }
  },
  "$defs": {
    "additionalContextEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "value"
      ],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "semantic_type": {
          "type": "string",
          "enum": [
            "descriptive_only",
            "actor_context",
            "business_scope",
            "time_scope",
            "participating_services",
            "orchestration_step"
          ]
        },
        "role": {
          "type": "string",
          "enum": [
            "descriptive",
            "design_driving"
          ]
        },
        "description": {
          "type": "string",
          "maxLength": 1000
        }
      }
    },
    "contextValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contextValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/contextValue"
          }
        }
      ]
    }
  }
}
