{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ANIP Studio",
  "version": "0.9.0",
  "identifier": "dev.anip.studio",
  "build": {
    "beforeDevCommand": "npm run dev:desktop",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build:desktop",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ANIP Studio",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "visible": false,
        "backgroundColor": "#f6efe1",
        "fullscreen": false
      },
      {
        "label": "splashscreen",
        "title": "ANIP Studio",
        "url": "splashscreen.html",
        "width": 460,
        "height": 300,
        "resizable": false,
        "decorations": false,
        "center": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "backgroundColor": "#f6efe1"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "resources": [
      "bin/anip-studio-api-*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Agent-native design environment for ANIP services",
    "longDescription": "ANIP Studio helps teams design, review, package, and validate governed agent-native service contracts."
  }
}
