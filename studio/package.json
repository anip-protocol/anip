{
  "name": "studio",
  "private": true,
  "version": "0.9.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "cross-env VITE_STUDIO_DESKTOP=1 VITE_STUDIO_API_BASE=http://127.0.0.1:8100 vite",
    "build": "vue-tsc -b && vite build",
    "build:desktop": "cross-env VITE_STUDIO_DESKTOP=1 VITE_STUDIO_API_BASE=http://127.0.0.1:8100 vue-tsc -b && cross-env VITE_STUDIO_DESKTOP=1 VITE_STUDIO_API_BASE=http://127.0.0.1:8100 vite build",
    "preview": "vite preview",
    "build:desktop-api": "bash scripts/build-desktop-api-sidecar.sh",
    "desktop:dev": "tauri dev",
    "desktop:build": "npm run build:desktop-api && tauri build",
    "test": "vitest run",
    "build:packs": "tsx scripts/build-design-packs.ts",
    "compare:package-semantics": "tsx scripts/compare-package-semantics.ts",
    "verify:showcase-release": "python3 scripts/verify-showcase-release-parity.py"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@vue-flow/core": "^1.48.2",
    "ajv": "^8.18.0",
    "js-yaml": "^4.1.1",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "cross-env": "^10.1.0",
    "jsdom": "^29.0.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.5"
  }
}
