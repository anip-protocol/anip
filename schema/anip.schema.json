{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anip.dev/schema/v0.8/anip.schema.json",
  "title": "ANIP \u2014 Agent-Native Interface Protocol",
  "description": "Canonical JSON Schema for all ANIP v0.8 types as defined in SPEC.md. Use these schemas to validate ANIP documents, responses, and delegation tokens.",
  "$defs": {
    "ConcurrentBranches": {
      "enum": [
        "allowed",
        "exclusive"
      ],
      "title": "ConcurrentBranches",
      "type": "string",
      "description": "Whether concurrent delegation branches are allowed or exclusive. See SPEC.md §4.3."
    },
    "DelegationConstraints": {
      "properties": {
        "max_delegation_depth": {
          "default": 3,
          "title": "Max Delegation Depth",
          "type": "integer"
        },
        "concurrent_branches": {
          "$ref": "#/$defs/ConcurrentBranches",
          "default": "allowed"
        }
      },
      "title": "DelegationConstraints",
      "type": "object",
      "description": "Constraints on delegation chain behavior. See SPEC.md §4.3."
    },
    "Purpose": {
      "properties": {
        "capability": {
          "title": "Capability",
          "type": "string"
        },
        "parameters": {
          "additionalProperties": true,
          "title": "Parameters",
          "type": "object"
        },
        "task_id": {
          "title": "Task Id",
          "type": "string"
        }
      },
      "required": [
        "capability",
        "task_id"
      ],
      "title": "Purpose",
      "type": "object",
      "description": "Purpose binding for a delegation token — which capability and task it authorizes. See SPEC.md §4.3."
    },
    "ResponseMode": {
      "enum": ["unary", "streaming"],
      "title": "ResponseMode",
      "type": "string"
    },
    "CapabilityComposition": {
      "properties": {
        "capability": {
          "title": "Capability",
          "type": "string"
        },
        "optional": {
          "default": true,
          "title": "Optional",
          "type": "boolean"
        }
      },
      "required": [
        "capability"
      ],
      "title": "CapabilityComposition",
      "type": "object"
    },
    "CapabilityInput": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "type": {
          "title": "Type",
          "type": "string"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "default": {
          "default": null,
          "title": "Default"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "name",
        "type"
      ],
      "title": "CapabilityInput",
      "type": "object"
    },
    "CapabilityOutput": {
      "properties": {
        "type": {
          "title": "Type",
          "type": "string"
        },
        "fields": {
          "items": {
            "type": "string"
          },
          "title": "Fields",
          "type": "array"
        }
      },
      "required": [
        "type",
        "fields"
      ],
      "title": "CapabilityOutput",
      "type": "object"
    },
    "CapabilityRequirement": {
      "properties": {
        "capability": {
          "title": "Capability",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "capability",
        "reason"
      ],
      "title": "CapabilityRequirement",
      "type": "object"
    },
    "Cost": {
      "properties": {
        "certainty": {
          "$ref": "#/$defs/CostCertainty",
          "default": "fixed"
        },
        "financial": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Financial"
        },
        "determined_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Determined By"
        },
        "factors": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Factors"
        },
        "compute": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Compute"
        },
        "rate_limit": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rate Limit"
        }
      },
      "title": "Cost",
      "type": "object"
    },
    "CostCertainty": {
      "enum": [
        "fixed",
        "estimated",
        "dynamic"
      ],
      "title": "CostCertainty",
      "type": "string"
    },
    "ObservabilityContract": {
      "properties": {
        "logged": {
          "default": true,
          "title": "Logged",
          "type": "boolean"
        },
        "retention": {
          "default": "P90D",
          "title": "Retention",
          "type": "string"
        },
        "fields_logged": {
          "items": {
            "type": "string"
          },
          "title": "Fields Logged",
          "type": "array"
        },
        "audit_accessible_by": {
          "items": {
            "type": "string"
          },
          "title": "Audit Accessible By",
          "type": "array"
        }
      },
      "title": "ObservabilityContract",
      "type": "object"
    },
    "SessionInfo": {
      "properties": {
        "type": {
          "$ref": "#/$defs/SessionType",
          "default": "stateless"
        }
      },
      "title": "SessionInfo",
      "type": "object"
    },
    "SessionType": {
      "enum": [
        "stateless",
        "continuation",
        "workflow"
      ],
      "title": "SessionType",
      "type": "string"
    },
    "StreamSummary": {
      "properties": {
        "response_mode": { "const": "streaming" },
        "events_emitted": { "type": "integer", "minimum": 0 },
        "events_delivered": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "client_disconnected": { "type": "boolean" }
      },
      "required": ["response_mode", "events_emitted", "events_delivered", "duration_ms", "client_disconnected"],
      "title": "StreamSummary",
      "type": "object"
    },
    "SideEffect": {
      "properties": {
        "type": {
          "$ref": "#/$defs/SideEffectType"
        },
        "rollback_window": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rollback Window"
        }
      },
      "required": [
        "type"
      ],
      "title": "SideEffect",
      "type": "object"
    },
    "SideEffectType": {
      "enum": [
        "read",
        "write",
        "irreversible",
        "transactional"
      ],
      "title": "SideEffectType",
      "type": "string"
    },
    "EventClass": {
      "enum": [
        "high_risk_success",
        "high_risk_denial",
        "low_risk_success",
        "repeated_low_value_denial",
        "malformed_or_spam"
      ],
      "title": "EventClass",
      "type": "string",
      "description": "Classification of an audit event by risk level. See SPEC.md §6.8."
    },
    "RetentionTier": {
      "enum": [
        "long",
        "medium",
        "short",
        "aggregate_only"
      ],
      "title": "RetentionTier",
      "type": "string",
      "description": "Retention tier governing how long an audit entry is kept. See SPEC.md §6.8."
    },
    "DisclosureLevel": {
      "enum": [
        "full",
        "reduced",
        "redacted",
        "policy"
      ],
      "title": "DisclosureLevel",
      "type": "string",
      "description": "How much failure detail is surfaced to callers. See SPEC.md §6.8."
    },
    "AvailableCapability": {
      "properties": {
        "capability": {
          "title": "Capability",
          "type": "string"
        },
        "scope_match": {
          "title": "Scope Match",
          "type": "string"
        },
        "constraints": {
          "additionalProperties": true,
          "title": "Constraints",
          "type": "object"
        }
      },
      "required": [
        "capability",
        "scope_match"
      ],
      "title": "AvailableCapability",
      "type": "object"
    },
    "DeniedCapability": {
      "properties": {
        "capability": {
          "title": "Capability",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "capability",
        "reason"
      ],
      "title": "DeniedCapability",
      "type": "object"
    },
    "RestrictedCapability": {
      "properties": {
        "capability": {
          "title": "Capability",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "grantable_by": {
          "title": "Grantable By",
          "type": "string"
        }
      },
      "required": [
        "capability",
        "reason",
        "grantable_by"
      ],
      "title": "RestrictedCapability",
      "type": "object"
    },
    "Resolution": {
      "properties": {
        "action": {
          "title": "Action",
          "type": "string"
        },
        "requires": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Requires"
        },
        "grantable_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Grantable By"
        },
        "estimated_availability": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Availability"
        }
      },
      "required": [
        "action"
      ],
      "title": "Resolution",
      "type": "object"
    },
    "DelegationToken": {
      "properties": {
        "token_id": {
          "title": "Token Id",
          "type": "string"
        },
        "issuer": {
          "title": "Issuer",
          "type": "string"
        },
        "subject": {
          "title": "Subject",
          "type": "string"
        },
        "scope": {
          "items": {
            "type": "string"
          },
          "title": "Scope",
          "type": "array"
        },
        "purpose": {
          "$ref": "#/$defs/Purpose"
        },
        "parent": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent"
        },
        "expires": {
          "format": "date-time",
          "title": "Expires",
          "type": "string"
        },
        "constraints": {
          "$ref": "#/$defs/DelegationConstraints"
        }
      },
      "required": [
        "token_id",
        "issuer",
        "subject",
        "scope",
        "purpose",
        "expires"
      ],
      "title": "DelegationToken",
      "type": "object",
      "description": "A delegation token representing scoped authority in a delegation chain (DAG). See SPEC.md §4.3."
    },
    "ANIPFailure": {
      "properties": {
        "type": {
          "title": "Type",
          "type": "string"
        },
        "detail": {
          "title": "Detail",
          "type": "string"
        },
        "resolution": {
          "$ref": "#/$defs/Resolution"
        },
        "retry": {
          "default": true,
          "title": "Retry",
          "type": "boolean"
        }
      },
      "required": [
        "type",
        "detail",
        "resolution"
      ],
      "title": "ANIPFailure",
      "type": "object",
      "description": "Structured failure object with type, detail, resolution path, and retry hint. See SPEC.md §4.5."
    },
    "CostActual": {
      "properties": {
        "financial": {
          "additionalProperties": true,
          "title": "Financial",
          "type": "object"
        },
        "variance_from_estimate": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Variance From Estimate"
        }
      },
      "required": [
        "financial"
      ],
      "title": "CostActual",
      "type": "object"
    },
    "CapabilityDeclaration": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "contract_version": {
          "default": "1.0",
          "title": "Contract Version",
          "type": "string"
        },
        "inputs": {
          "items": {
            "$ref": "#/$defs/CapabilityInput"
          },
          "title": "Inputs",
          "type": "array"
        },
        "output": {
          "$ref": "#/$defs/CapabilityOutput"
        },
        "side_effect": {
          "$ref": "#/$defs/SideEffect"
        },
        "minimum_scope": {
          "title": "Minimum Scope",
          "type": "array",
          "items": { "type": "string" },
          "description": "Delegation scopes required to invoke this capability (AND semantics). Matches discovery document's minimum_scope field."
        },
        "cost": {
          "anyOf": [
            {
              "$ref": "#/$defs/Cost"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "requires": {
          "items": {
            "$ref": "#/$defs/CapabilityRequirement"
          },
          "title": "Requires",
          "type": "array"
        },
        "composes_with": {
          "items": {
            "$ref": "#/$defs/CapabilityComposition"
          },
          "title": "Composes With",
          "type": "array"
        },
        "session": {
          "$ref": "#/$defs/SessionInfo"
        },
        "observability": {
          "anyOf": [
            {
              "$ref": "#/$defs/ObservabilityContract"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "response_modes": {
          "items": {
            "$ref": "#/$defs/ResponseMode"
          },
          "minItems": 1,
          "uniqueItems": true,
          "default": ["unary"],
          "title": "Response Modes",
          "type": "array"
        }
      },
      "required": [
        "name",
        "description",
        "inputs",
        "output",
        "side_effect",
        "minimum_scope"
      ],
      "title": "CapabilityDeclaration",
      "type": "object",
      "description": "Full capability declaration with inputs, outputs, side effects, cost, and observability. See SPEC.md §4.1."
    },
    "ProfileVersions": {
      "properties": {
        "core": {
          "default": "1.0",
          "title": "Core",
          "type": "string"
        },
        "cost": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cost"
        },
        "capability_graph": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Capability Graph"
        },
        "state_session": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "State Session"
        },
        "observability": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observability"
        }
      },
      "title": "ProfileVersions",
      "type": "object"
    },
    "PermissionResponse": {
      "properties": {
        "available": {
          "items": {
            "$ref": "#/$defs/AvailableCapability"
          },
          "title": "Available",
          "type": "array"
        },
        "restricted": {
          "items": {
            "$ref": "#/$defs/RestrictedCapability"
          },
          "title": "Restricted",
          "type": "array"
        },
        "denied": {
          "items": {
            "$ref": "#/$defs/DeniedCapability"
          },
          "title": "Denied",
          "type": "array"
        }
      },
      "title": "PermissionResponse",
      "type": "object",
      "description": "Response from permission discovery — available, restricted, and denied capabilities. See SPEC.md §4.4."
    },
    "InvokeRequest": {
      "properties": {
        "token": {
          "title": "Token",
          "type": "string"
        },
        "parameters": {
          "additionalProperties": true,
          "title": "Parameters",
          "type": "object"
        },
        "budget": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Budget"
        },
        "stream": {
          "default": false,
          "title": "Stream",
          "type": "boolean"
        },
        "client_reference_id": {
          "anyOf": [
            { "type": "string", "maxLength": 256 },
            { "type": "null" }
          ],
          "default": null,
          "title": "Client Reference Id"
        }
      },
      "required": [
        "token"
      ],
      "title": "InvokeRequest",
      "type": "object"
    },
    "InvokeResponse": {
      "properties": {
        "invocation_id": {
          "title": "Invocation Id",
          "type": "string",
          "pattern": "^inv-[0-9a-f]{12}$"
        },
        "success": {
          "title": "Success",
          "type": "boolean"
        },
        "result": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Result"
        },
        "cost_actual": {
          "anyOf": [
            {
              "$ref": "#/$defs/CostActual"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "failure": {
          "anyOf": [
            {
              "$ref": "#/$defs/ANIPFailure"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "session": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Session"
        },
        "stream_summary": {
          "anyOf": [
            { "$ref": "#/$defs/StreamSummary" },
            { "type": "null" }
          ],
          "default": null
        },
        "client_reference_id": {
          "anyOf": [
            { "type": "string", "maxLength": 256 },
            { "type": "null" }
          ],
          "default": null,
          "title": "Client Reference Id"
        }
      },
      "required": [
        "invocation_id",
        "success"
      ],
      "if": {
        "properties": { "success": { "const": true } },
        "required": ["success"]
      },
      "then": {
        "required": ["result"],
        "properties": {
          "result": {
            "not": { "type": "null" }
          }
        }
      },
      "else": {
        "required": ["failure"],
        "properties": {
          "failure": {
            "not": { "type": "null" }
          }
        }
      },
      "title": "InvokeResponse",
      "type": "object",
      "description": "Response from capability invocation — result or failure with optional cost actual. See SPEC.md §6.2."
    },
    "ANIPManifest": {
      "properties": {
        "protocol": {
          "default": "anip/1.0",
          "title": "Protocol",
          "type": "string"
        },
        "profile": {
          "$ref": "#/$defs/ProfileVersions"
        },
        "capabilities": {
          "additionalProperties": {
            "$ref": "#/$defs/CapabilityDeclaration"
          },
          "title": "Capabilities",
          "type": "object"
        }
      },
      "required": [
        "profile",
        "capabilities"
      ],
      "title": "ANIPManifest",
      "type": "object",
      "description": "The full ANIP manifest — protocol version, profile versions, and all capability declarations. See SPEC.md §6.2."
    },
    "AuditEntry": {
      "properties": {
        "sequence_number": {
          "title": "Sequence Number",
          "type": "integer"
        },
        "timestamp": {
          "title": "Timestamp",
          "type": "string",
          "format": "date-time"
        },
        "capability": {
          "title": "Capability",
          "type": "string"
        },
        "invocation_id": {
          "title": "Invocation ID",
          "type": "string"
        },
        "client_reference_id": {
          "title": "Client Reference ID",
          "type": ["string", "null"]
        },
        "success": {
          "title": "Success",
          "type": "boolean"
        },
        "event_class": {
          "$ref": "#/$defs/EventClass"
        },
        "retention_tier": {
          "$ref": "#/$defs/RetentionTier"
        },
        "expires_at": {
          "title": "Expires At",
          "type": ["string", "null"],
          "format": "date-time",
          "description": "When this entry will be deleted by retention enforcement, or null for indefinite retention"
        }
      },
      "required": ["sequence_number", "timestamp", "capability", "success", "event_class", "retention_tier"],
      "title": "AuditEntry",
      "type": "object",
      "description": "An entry in the audit log with v0.8 classification and retention fields. See SPEC.md §6.5 and §6.8."
    },
    "CheckpointResponse": {
      "properties": {
        "checkpoint": {
          "type": "object",
          "properties": {
            "checkpoint_id": {
              "title": "Checkpoint ID",
              "type": "string"
            },
            "range": {
              "type": "object",
              "properties": {
                "first_sequence": { "type": "integer" },
                "last_sequence": { "type": "integer" }
              },
              "required": ["first_sequence", "last_sequence"]
            },
            "merkle_root": {
              "title": "Merkle Root",
              "type": "string"
            },
            "previous_checkpoint": {
              "title": "Previous Checkpoint",
              "type": ["string", "null"]
            },
            "timestamp": {
              "title": "Timestamp",
              "type": "string",
              "format": "date-time"
            },
            "entry_count": {
              "title": "Entry Count",
              "type": "integer"
            },
            "signature": {
              "title": "Signature",
              "type": "string"
            }
          },
          "required": ["checkpoint_id", "range", "merkle_root", "timestamp", "entry_count"]
        },
        "proof_unavailable": {
          "title": "Proof Unavailable",
          "type": "string",
          "description": "Present when proof cannot be generated, e.g. 'audit_entries_expired' when retention has deleted entries needed for proof. The checkpoint data is still valid."
        }
      },
      "required": ["checkpoint"],
      "title": "CheckpointResponse",
      "type": "object",
      "description": "A Merkle checkpoint with optional proof. proof_unavailable indicates why proof generation failed. See SPEC.md §6.6 and §6.8."
    }
  }
}
