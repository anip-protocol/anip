{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anip.dev/schema/v0.14/anip.schema.json",
  "title": "ANIP \u2014 Agent-Native Interface Protocol",
  "description": "Canonical JSON Schema for all ANIP v0.14 types as defined in SPEC.md. Use these schemas to validate ANIP documents, responses, and delegation tokens.",
  "$defs": {
    "ConcurrentBranches": {
      "enum": [
        "allowed",
        "exclusive"
      ],
      "title": "ConcurrentBranches",
      "type": "string",
      "description": "Whether concurrent delegation branches are allowed or exclusive. See SPEC.md §4.3."
    },
    "Budget": {
      "properties": {
        "currency": {
          "title": "Currency",
          "type": "string",
          "description": "ISO 4217 currency code (e.g., USD, EUR)"
        },
        "max_amount": {
          "title": "Max Amount",
          "type": "number",
          "minimum": 0,
          "description": "Maximum amount the delegation authorizes"
        }
      },
      "required": ["currency", "max_amount"],
      "title": "Budget",
      "type": "object",
      "description": "Enforceable financial budget constraint in delegation tokens. See SPEC.md §4.3."
    },
    "BudgetContext": {
      "properties": {
        "budget_max": {
          "title": "Budget Max",
          "type": "number",
          "description": "The max_amount from the delegation token's budget constraint"
        },
        "budget_currency": {
          "title": "Budget Currency",
          "type": "string",
          "description": "The currency from the delegation token's budget constraint"
        },
        "cost_check_amount": {
          "title": "Cost Check Amount",
          "type": "number",
          "description": "The amount used for the pre-execution budget check"
        },
        "cost_certainty": {
          "$ref": "#/$defs/CostCertainty",
          "description": "The certainty level used in the budget check"
        },
        "cost_actual": {
          "anyOf": [
            { "type": "number" },
            { "type": "null" }
          ],
          "default": null,
          "title": "Cost Actual",
          "description": "Actual cost after execution, null when not yet known or on pre-execution failure"
        },
        "within_budget": {
          "title": "Within Budget",
          "type": "boolean",
          "description": "Whether the actual cost was within the budget constraint"
        }
      },
      "required": ["budget_max", "budget_currency", "cost_check_amount", "cost_certainty", "within_budget"],
      "title": "BudgetContext",
      "type": "object",
      "description": "Budget enforcement context included in invoke responses when a budget was evaluated. Present on both success and failure. See SPEC.md §6.3."
    },
    "BindingRequirement": {
      "properties": {
        "type": {
          "title": "Type",
          "type": "string",
          "description": "Binding type identifier (e.g., quote, offer, price_lock)"
        },
        "field": {
          "title": "Field",
          "type": "string",
          "description": "Which field in invocation parameters must carry the reference"
        },
        "source_capability": {
          "anyOf": [
            { "type": "string" },
            { "type": "null" }
          ],
          "default": null,
          "title": "Source Capability",
          "description": "Advisory — which capability produces this binding"
        },
        "max_age": {
          "anyOf": [
            { "type": "string" },
            { "type": "null" }
          ],
          "default": null,
          "title": "Max Age",
          "description": "ISO 8601 duration — maximum age before binding is considered stale"
        }
      },
      "required": ["type", "field"],
      "title": "BindingRequirement",
      "type": "object",
      "description": "Execution-time binding requirement for a capability. See SPEC.md §4.1."
    },
    "ControlRequirementType": {
      "enum": [
        "cost_ceiling",
        "stronger_delegation_required"
      ],
      "title": "ControlRequirementType",
      "type": "string",
      "description": "Type of control requirement. All types are token-evaluable: cost_ceiling, stronger_delegation_required. See SPEC.md §4.1."
    },
    "ControlRequirementEnforcement": {
      "enum": [
        "reject"
      ],
      "title": "ControlRequirementEnforcement",
      "type": "string",
      "description": "Enforcement mode for control requirements. v0.14 supports reject only. See SPEC.md §4.1."
    },
    "ControlRequirement": {
      "properties": {
        "type": {
          "$ref": "#/$defs/ControlRequirementType"
        },
        "enforcement": {
          "$ref": "#/$defs/ControlRequirementEnforcement"
        }
      },
      "required": ["type", "enforcement"],
      "title": "ControlRequirement",
      "type": "object",
      "description": "Token-evaluable control requirement declaration for a capability. All control requirements can be checked from the delegation token alone. See SPEC.md §4.1."
    },
    "DelegationConstraints": {
      "properties": {
        "max_delegation_depth": {
          "default": 3,
          "title": "Max Delegation Depth",
          "type": "integer"
        },
        "concurrent_branches": {
          "$ref": "#/$defs/ConcurrentBranches",
          "default": "allowed"
        },
        "budget": {
          "anyOf": [
            { "$ref": "#/$defs/Budget" },
            { "type": "null" }
          ],
          "default": null,
          "description": "Enforceable financial budget constraint. Child budgets MUST NOT exceed parent. See SPEC.md §4.3."
        }
      },
      "title": "DelegationConstraints",
      "type": "object",
      "description": "Constraints on delegation chain behavior. See SPEC.md §4.3."
    },
    "Purpose": {
      "properties": {
        "capability": {
          "title": "Capability",
          "type": "string"
        },
        "parameters": {
          "additionalProperties": true,
          "title": "Parameters",
          "type": "object"
        },
        "task_id": {
          "title": "Task Id",
          "type": "string"
        }
      },
      "required": [
        "capability",
        "task_id"
      ],
      "title": "Purpose",
      "type": "object",
      "description": "Purpose binding for a delegation token — which capability and task it authorizes. See SPEC.md §4.3."
    },
    "ResponseMode": {
      "enum": ["unary", "streaming"],
      "title": "ResponseMode",
      "type": "string"
    },
    "CapabilityComposition": {
      "properties": {
        "capability": {
          "title": "Capability",
          "type": "string"
        },
        "optional": {
          "default": true,
          "title": "Optional",
          "type": "boolean"
        }
      },
      "required": [
        "capability"
      ],
      "title": "CapabilityComposition",
      "type": "object"
    },
    "CapabilityInput": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "type": {
          "title": "Type",
          "type": "string"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "default": {
          "default": null,
          "title": "Default"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "name",
        "type"
      ],
      "title": "CapabilityInput",
      "type": "object"
    },
    "CapabilityOutput": {
      "properties": {
        "type": {
          "title": "Type",
          "type": "string"
        },
        "fields": {
          "items": {
            "type": "string"
          },
          "title": "Fields",
          "type": "array"
        }
      },
      "required": [
        "type",
        "fields"
      ],
      "title": "CapabilityOutput",
      "type": "object"
    },
    "CapabilityRequirement": {
      "properties": {
        "capability": {
          "title": "Capability",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "capability",
        "reason"
      ],
      "title": "CapabilityRequirement",
      "type": "object"
    },
    "Cost": {
      "properties": {
        "certainty": {
          "$ref": "#/$defs/CostCertainty",
          "default": "fixed"
        },
        "financial": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Financial"
        },
        "determined_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Determined By"
        },
        "factors": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Factors"
        },
        "compute": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Compute"
        },
        "rate_limit": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rate Limit"
        }
      },
      "title": "Cost",
      "type": "object"
    },
    "CostCertainty": {
      "enum": [
        "fixed",
        "estimated",
        "dynamic"
      ],
      "title": "CostCertainty",
      "type": "string"
    },
    "ObservabilityContract": {
      "properties": {
        "logged": {
          "default": true,
          "title": "Logged",
          "type": "boolean"
        },
        "retention": {
          "default": "P90D",
          "title": "Retention",
          "type": "string"
        },
        "fields_logged": {
          "items": {
            "type": "string"
          },
          "title": "Fields Logged",
          "type": "array"
        },
        "audit_accessible_by": {
          "items": {
            "type": "string"
          },
          "title": "Audit Accessible By",
          "type": "array"
        }
      },
      "title": "ObservabilityContract",
      "type": "object"
    },
    "SessionInfo": {
      "properties": {
        "type": {
          "$ref": "#/$defs/SessionType",
          "default": "stateless"
        }
      },
      "title": "SessionInfo",
      "type": "object"
    },
    "SessionType": {
      "enum": [
        "stateless",
        "continuation",
        "workflow"
      ],
      "title": "SessionType",
      "type": "string"
    },
    "StreamSummary": {
      "properties": {
        "response_mode": { "const": "streaming" },
        "events_emitted": { "type": "integer", "minimum": 0 },
        "events_delivered": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "client_disconnected": { "type": "boolean" }
      },
      "required": ["response_mode", "events_emitted", "events_delivered", "duration_ms", "client_disconnected"],
      "title": "StreamSummary",
      "type": "object"
    },
    "SideEffect": {
      "properties": {
        "type": {
          "$ref": "#/$defs/SideEffectType"
        },
        "rollback_window": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rollback Window"
        }
      },
      "required": [
        "type"
      ],
      "title": "SideEffect",
      "type": "object"
    },
    "SideEffectType": {
      "enum": [
        "read",
        "write",
        "irreversible",
        "transactional"
      ],
      "title": "SideEffectType",
      "type": "string"
    },
    "EventClass": {
      "enum": [
        "high_risk_success",
        "high_risk_denial",
        "low_risk_success",
        "repeated_low_value_denial",
        "malformed_or_spam"
      ],
      "title": "EventClass",
      "type": "string",
      "description": "Classification of an audit event by risk level. See SPEC.md §6.8."
    },
    "RetentionTier": {
      "enum": [
        "long",
        "medium",
        "short",
        "aggregate_only"
      ],
      "title": "RetentionTier",
      "type": "string",
      "description": "Retention tier governing how long an audit entry is kept. See SPEC.md §6.8."
    },
    "DisclosureLevel": {
      "enum": [
        "full",
        "reduced",
        "redacted",
        "policy"
      ],
      "title": "DisclosureLevel",
      "type": "string",
      "description": "How much failure detail is surfaced to callers. See SPEC.md §6.8."
    },
    "AvailableCapability": {
      "properties": {
        "capability": {
          "title": "Capability",
          "type": "string"
        },
        "scope_match": {
          "title": "Scope Match",
          "type": "string"
        },
        "constraints": {
          "additionalProperties": true,
          "title": "Constraints",
          "type": "object"
        }
      },
      "required": [
        "capability",
        "scope_match"
      ],
      "title": "AvailableCapability",
      "type": "object"
    },
    "DeniedCapability": {
      "properties": {
        "capability": {
          "title": "Capability",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "capability",
        "reason"
      ],
      "title": "DeniedCapability",
      "type": "object"
    },
    "RestrictedCapability": {
      "properties": {
        "capability": {
          "title": "Capability",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "grantable_by": {
          "title": "Grantable By",
          "type": "string"
        },
        "unmet_token_requirements": {
          "anyOf": [
            {
              "items": { "type": "string" },
              "type": "array"
            },
            { "type": "null" }
          ],
          "default": null,
          "title": "Unmet Token Requirements",
          "description": "Token-evaluable control requirements not satisfied (e.g., cost_ceiling, stronger_delegation_required). See SPEC.md §4.4."
        }
      },
      "required": [
        "capability",
        "reason",
        "grantable_by"
      ],
      "title": "RestrictedCapability",
      "type": "object"
    },
    "Resolution": {
      "properties": {
        "action": {
          "title": "Action",
          "type": "string"
        },
        "requires": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Requires"
        },
        "grantable_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Grantable By"
        },
        "estimated_availability": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Availability"
        }
      },
      "required": [
        "action"
      ],
      "title": "Resolution",
      "type": "object"
    },
    "DelegationToken": {
      "properties": {
        "token_id": {
          "title": "Token Id",
          "type": "string"
        },
        "issuer": {
          "title": "Issuer",
          "type": "string"
        },
        "subject": {
          "title": "Subject",
          "type": "string"
        },
        "scope": {
          "items": {
            "type": "string"
          },
          "title": "Scope",
          "type": "array"
        },
        "purpose": {
          "$ref": "#/$defs/Purpose"
        },
        "parent": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent"
        },
        "expires": {
          "format": "date-time",
          "title": "Expires",
          "type": "string"
        },
        "constraints": {
          "$ref": "#/$defs/DelegationConstraints"
        }
      },
      "required": [
        "token_id",
        "issuer",
        "subject",
        "scope",
        "purpose",
        "expires"
      ],
      "title": "DelegationToken",
      "type": "object",
      "description": "A delegation token representing scoped authority in a delegation chain (DAG). See SPEC.md §4.3."
    },
    "ANIPFailure": {
      "properties": {
        "type": {
          "title": "Type",
          "type": "string"
        },
        "detail": {
          "title": "Detail",
          "type": "string"
        },
        "resolution": {
          "$ref": "#/$defs/Resolution"
        },
        "retry": {
          "default": true,
          "title": "Retry",
          "type": "boolean"
        }
      },
      "required": [
        "type",
        "detail",
        "resolution"
      ],
      "title": "ANIPFailure",
      "type": "object",
      "description": "Structured failure object with type, detail, resolution path, and retry hint. See SPEC.md §4.5."
    },
    "CostActual": {
      "properties": {
        "financial": {
          "additionalProperties": true,
          "title": "Financial",
          "type": "object"
        },
        "variance_from_estimate": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Variance From Estimate"
        }
      },
      "required": [
        "financial"
      ],
      "title": "CostActual",
      "type": "object"
    },
    "CapabilityDeclaration": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "contract_version": {
          "default": "1.0",
          "title": "Contract Version",
          "type": "string"
        },
        "inputs": {
          "items": {
            "$ref": "#/$defs/CapabilityInput"
          },
          "title": "Inputs",
          "type": "array"
        },
        "output": {
          "$ref": "#/$defs/CapabilityOutput"
        },
        "side_effect": {
          "$ref": "#/$defs/SideEffect"
        },
        "minimum_scope": {
          "title": "Minimum Scope",
          "type": "array",
          "items": { "type": "string" },
          "description": "Delegation scopes required to invoke this capability (AND semantics). Matches discovery document's minimum_scope field."
        },
        "cost": {
          "anyOf": [
            {
              "$ref": "#/$defs/Cost"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "requires": {
          "items": {
            "$ref": "#/$defs/CapabilityRequirement"
          },
          "title": "Requires",
          "type": "array"
        },
        "composes_with": {
          "items": {
            "$ref": "#/$defs/CapabilityComposition"
          },
          "title": "Composes With",
          "type": "array"
        },
        "session": {
          "$ref": "#/$defs/SessionInfo"
        },
        "observability": {
          "anyOf": [
            {
              "$ref": "#/$defs/ObservabilityContract"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "response_modes": {
          "items": {
            "$ref": "#/$defs/ResponseMode"
          },
          "minItems": 1,
          "uniqueItems": true,
          "default": ["unary"],
          "title": "Response Modes",
          "type": "array"
        },
        "requires_binding": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/BindingRequirement"
              },
              "type": "array"
            },
            { "type": "null" }
          ],
          "default": null,
          "title": "Requires Binding",
          "description": "Execution-time binding requirements. See SPEC.md §4.1."
        },
        "control_requirements": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/ControlRequirement"
              },
              "type": "array"
            },
            { "type": "null" }
          ],
          "default": null,
          "title": "Control Requirements",
          "description": "Explicit control requirement declarations. See SPEC.md §4.1."
        }
      },
      "required": [
        "name",
        "description",
        "inputs",
        "output",
        "side_effect",
        "minimum_scope"
      ],
      "title": "CapabilityDeclaration",
      "type": "object",
      "description": "Full capability declaration with inputs, outputs, side effects, cost, and observability. See SPEC.md §4.1."
    },
    "ProfileVersions": {
      "properties": {
        "core": {
          "default": "1.0",
          "title": "Core",
          "type": "string"
        },
        "cost": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cost"
        },
        "capability_graph": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Capability Graph"
        },
        "state_session": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "State Session"
        },
        "observability": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observability"
        }
      },
      "title": "ProfileVersions",
      "type": "object"
    },
    "PermissionResponse": {
      "properties": {
        "available": {
          "items": {
            "$ref": "#/$defs/AvailableCapability"
          },
          "title": "Available",
          "type": "array"
        },
        "restricted": {
          "items": {
            "$ref": "#/$defs/RestrictedCapability"
          },
          "title": "Restricted",
          "type": "array"
        },
        "denied": {
          "items": {
            "$ref": "#/$defs/DeniedCapability"
          },
          "title": "Denied",
          "type": "array"
        }
      },
      "title": "PermissionResponse",
      "type": "object",
      "description": "Response from permission discovery — available, restricted, and denied capabilities. See SPEC.md §4.4."
    },
    "InvokeRequest": {
      "properties": {
        "token": {
          "title": "Token",
          "type": "string"
        },
        "parameters": {
          "additionalProperties": true,
          "title": "Parameters",
          "type": "object"
        },
        "budget": {
          "anyOf": [
            { "$ref": "#/$defs/Budget" },
            { "type": "null" }
          ],
          "default": null,
          "title": "Budget",
          "description": "Negotiation hint — MUST NOT widen the token's constraints.budget. See SPEC.md §6.3."
        },
        "stream": {
          "default": false,
          "title": "Stream",
          "type": "boolean"
        },
        "client_reference_id": {
          "anyOf": [
            { "type": "string", "maxLength": 256 },
            { "type": "null" }
          ],
          "default": null,
          "title": "Client Reference Id"
        },
        "task_id": {
          "anyOf": [
            { "type": "string", "maxLength": 256 },
            { "type": "null" }
          ],
          "default": null,
          "title": "Task Id",
          "description": "Caller-supplied task/workflow identity for grouping related invocations"
        },
        "parent_invocation_id": {
          "anyOf": [
            { "type": "string", "pattern": "^inv-[0-9a-f]{12}$" },
            { "type": "null" }
          ],
          "default": null,
          "title": "Parent Invocation Id",
          "description": "Reference to the invocation that triggered this one"
        }
      },
      "required": [
        "token"
      ],
      "title": "InvokeRequest",
      "type": "object"
    },
    "InvokeResponse": {
      "properties": {
        "invocation_id": {
          "title": "Invocation Id",
          "type": "string",
          "pattern": "^inv-[0-9a-f]{12}$"
        },
        "success": {
          "title": "Success",
          "type": "boolean"
        },
        "result": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Result"
        },
        "cost_actual": {
          "anyOf": [
            {
              "$ref": "#/$defs/CostActual"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "failure": {
          "anyOf": [
            {
              "$ref": "#/$defs/ANIPFailure"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "session": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Session"
        },
        "stream_summary": {
          "anyOf": [
            { "$ref": "#/$defs/StreamSummary" },
            { "type": "null" }
          ],
          "default": null
        },
        "client_reference_id": {
          "anyOf": [
            { "type": "string", "maxLength": 256 },
            { "type": "null" }
          ],
          "default": null,
          "title": "Client Reference Id"
        },
        "task_id": {
          "anyOf": [
            { "type": "string", "maxLength": 256 },
            { "type": "null" }
          ],
          "default": null,
          "title": "Task Id",
          "description": "Caller-supplied task/workflow identity for grouping related invocations"
        },
        "parent_invocation_id": {
          "anyOf": [
            { "type": "string", "pattern": "^inv-[0-9a-f]{12}$" },
            { "type": "null" }
          ],
          "default": null,
          "title": "Parent Invocation Id",
          "description": "Reference to the invocation that triggered this one"
        },
        "budget_context": {
          "anyOf": [
            { "$ref": "#/$defs/BudgetContext" },
            { "type": "null" }
          ],
          "default": null,
          "description": "Budget enforcement context, present on both success and failure when a budget was evaluated. See SPEC.md §6.3."
        }
      },
      "required": [
        "invocation_id",
        "success"
      ],
      "if": {
        "properties": { "success": { "const": true } },
        "required": ["success"]
      },
      "then": {
        "required": ["result"],
        "properties": {
          "result": {
            "not": { "type": "null" }
          }
        }
      },
      "else": {
        "required": ["failure"],
        "properties": {
          "failure": {
            "not": { "type": "null" }
          }
        }
      },
      "title": "InvokeResponse",
      "type": "object",
      "description": "Response from capability invocation — result or failure with optional cost actual. See SPEC.md §6.2."
    },
    "ANIPManifest": {
      "properties": {
        "protocol": {
          "default": "anip/1.0",
          "title": "Protocol",
          "type": "string"
        },
        "profile": {
          "$ref": "#/$defs/ProfileVersions"
        },
        "capabilities": {
          "additionalProperties": {
            "$ref": "#/$defs/CapabilityDeclaration"
          },
          "title": "Capabilities",
          "type": "object"
        }
      },
      "required": [
        "profile",
        "capabilities"
      ],
      "title": "ANIPManifest",
      "type": "object",
      "description": "The full ANIP manifest — protocol version, profile versions, and all capability declarations. See SPEC.md §6.2."
    },
    "AuditEntry": {
      "properties": {
        "sequence_number": {
          "title": "Sequence Number",
          "type": "integer"
        },
        "timestamp": {
          "title": "Timestamp",
          "type": "string",
          "format": "date-time"
        },
        "capability": {
          "title": "Capability",
          "type": "string"
        },
        "invocation_id": {
          "title": "Invocation ID",
          "type": "string"
        },
        "client_reference_id": {
          "title": "Client Reference ID",
          "type": ["string", "null"]
        },
        "task_id": {
          "title": "Task ID",
          "type": ["string", "null"],
          "description": "Task/workflow identity for grouping related invocations"
        },
        "parent_invocation_id": {
          "title": "Parent Invocation ID",
          "type": ["string", "null"],
          "description": "Reference to the invocation that triggered this one"
        },
        "success": {
          "title": "Success",
          "type": "boolean"
        },
        "event_class": {
          "$ref": "#/$defs/EventClass"
        },
        "retention_tier": {
          "$ref": "#/$defs/RetentionTier"
        },
        "expires_at": {
          "title": "Expires At",
          "type": ["string", "null"],
          "format": "date-time",
          "description": "When this entry will be deleted by retention enforcement, or null for indefinite retention"
        },
        "storage_redacted": {
          "title": "Storage Redacted",
          "type": "boolean",
          "default": false,
          "description": "Whether this entry has been redacted during storage (e.g., detail stripped for aggregate_only tier)"
        },
        "entry_type": {
          "title": "Entry Type",
          "type": "string",
          "enum": ["individual", "aggregated"],
          "default": "individual",
          "description": "Whether this is an individual or aggregated audit entry"
        },
        "aggregation_count": {
          "title": "Aggregation Count",
          "type": ["integer", "null"],
          "default": null,
          "description": "Number of events aggregated into this entry, present only when entry_type is 'aggregated'"
        },
        "first_seen": {
          "title": "First Seen",
          "type": ["string", "null"],
          "format": "date-time",
          "default": null,
          "description": "Timestamp of the first event in an aggregated entry"
        },
        "last_seen": {
          "title": "Last Seen",
          "type": ["string", "null"],
          "format": "date-time",
          "default": null,
          "description": "Timestamp of the last event in an aggregated entry"
        },
        "representative_detail": {
          "title": "Representative Detail",
          "type": ["string", "null"],
          "default": null,
          "description": "Representative detail string from one of the aggregated events"
        }
      },
      "required": ["sequence_number", "timestamp", "capability", "success", "event_class", "retention_tier"],
      "title": "AuditEntry",
      "type": "object",
      "description": "An entry in the audit log with v0.9 classification, retention, and aggregation fields. See SPEC.md §6.5 and §6.8."
    },
    "AggregatedAuditEntry": {
      "properties": {
        "entry_type": {
          "const": "aggregated",
          "title": "Entry Type",
          "description": "Discriminator indicating this is an aggregated entry"
        },
        "event_class": {
          "const": "repeated_low_value_denial",
          "title": "Event Class",
          "description": "Aggregated entries are always repeated_low_value_denial class"
        },
        "retention_tier": {
          "const": "aggregate_only",
          "title": "Retention Tier",
          "description": "Aggregated entries use aggregate_only retention"
        },
        "grouping_key": {
          "type": "object",
          "properties": {
            "actor_key": {
              "title": "Actor Key",
              "type": "string",
              "description": "Identifier for the actor (e.g., delegation token subject)"
            },
            "capability": {
              "title": "Capability",
              "type": "string",
              "description": "The capability that was denied"
            },
            "failure_type": {
              "title": "Failure Type",
              "type": "string",
              "description": "The type of failure (e.g., 'scope_insufficient')"
            }
          },
          "required": ["actor_key", "capability", "failure_type"],
          "title": "Grouping Key",
          "description": "The key used to group individual events into this aggregate"
        },
        "window": {
          "type": "object",
          "properties": {
            "start": {
              "title": "Start",
              "type": "string",
              "format": "date-time",
              "description": "Start of the aggregation window"
            },
            "end": {
              "title": "End",
              "type": "string",
              "format": "date-time",
              "description": "End of the aggregation window"
            }
          },
          "required": ["start", "end"],
          "title": "Window",
          "description": "The time window over which events were aggregated"
        },
        "count": {
          "title": "Count",
          "type": "integer",
          "minimum": 1,
          "description": "Number of events in this aggregate"
        },
        "first_seen": {
          "title": "First Seen",
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the first event in the aggregate"
        },
        "last_seen": {
          "title": "Last Seen",
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the last event in the aggregate"
        },
        "representative_detail": {
          "title": "Representative Detail",
          "type": ["string", "null"],
          "description": "Representative detail string from one of the aggregated events, or null"
        }
      },
      "required": ["entry_type", "event_class", "retention_tier", "grouping_key", "window", "count", "first_seen", "last_seen"],
      "title": "AggregatedAuditEntry",
      "type": "object",
      "description": "An aggregated audit entry combining multiple repeated low-value denials. See SPEC.md §6.8."
    },
    "CheckpointResponse": {
      "properties": {
        "checkpoint": {
          "type": "object",
          "properties": {
            "checkpoint_id": {
              "title": "Checkpoint ID",
              "type": "string"
            },
            "range": {
              "type": "object",
              "properties": {
                "first_sequence": { "type": "integer" },
                "last_sequence": { "type": "integer" }
              },
              "required": ["first_sequence", "last_sequence"]
            },
            "merkle_root": {
              "title": "Merkle Root",
              "type": "string"
            },
            "previous_checkpoint": {
              "title": "Previous Checkpoint",
              "type": ["string", "null"]
            },
            "timestamp": {
              "title": "Timestamp",
              "type": "string",
              "format": "date-time"
            },
            "entry_count": {
              "title": "Entry Count",
              "type": "integer"
            },
            "signature": {
              "title": "Signature",
              "type": "string"
            }
          },
          "required": ["checkpoint_id", "range", "merkle_root", "timestamp", "entry_count"]
        },
        "inclusion_proof": {
          "anyOf": [
            { "additionalProperties": true, "type": "object" },
            { "type": "null" }
          ],
          "default": null,
          "title": "Inclusion Proof"
        },
        "consistency_proof": {
          "anyOf": [
            { "additionalProperties": true, "type": "object" },
            { "type": "null" }
          ],
          "default": null,
          "title": "Consistency Proof"
        },
        "proof_unavailable": {
          "type": ["string", "null"],
          "default": null,
          "title": "Proof Unavailable",
          "description": "Present when proof cannot be generated, e.g. 'audit_entries_expired' when retention has deleted entries needed for proof. The checkpoint data is still valid."
        },
        "expires_hint": {
          "type": ["string", "null"],
          "default": null,
          "title": "Expires Hint",
          "description": "Best-effort ISO 8601 timestamp of earliest expected audit entry expiration in this checkpoint's range. Informational, not contractual. Not part of the signed checkpoint body."
        }
      },
      "required": ["checkpoint"],
      "title": "CheckpointResponse",
      "type": "object",
      "description": "A Merkle checkpoint with optional proof. proof_unavailable indicates why proof generation failed. expires_hint is best-effort, informational. See SPEC.md §6.6 and §6.8."
    }
  }
}
