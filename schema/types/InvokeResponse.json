{
  "$defs": {
    "ANIPFailure": {
      "properties": {
        "type": {
          "title": "Type",
          "type": "string"
        },
        "detail": {
          "title": "Detail",
          "type": "string"
        },
        "resolution": {
          "$ref": "#/$defs/Resolution"
        },
        "retry": {
          "default": true,
          "title": "Retry",
          "type": "boolean"
        }
      },
      "required": [
        "type",
        "detail",
        "resolution"
      ],
      "title": "ANIPFailure",
      "type": "object"
    },
    "CostActual": {
      "properties": {
        "financial": {
          "additionalProperties": true,
          "title": "Financial",
          "type": "object"
        },
        "variance_from_estimate": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Variance From Estimate"
        }
      },
      "required": [
        "financial"
      ],
      "title": "CostActual",
      "type": "object"
    },
    "Resolution": {
      "properties": {
        "action": {
          "title": "Action",
          "type": "string"
        },
        "requires": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Requires"
        },
        "grantable_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Grantable By"
        },
        "estimated_availability": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Availability"
        }
      },
      "required": [
        "action"
      ],
      "title": "Resolution",
      "type": "object"
    },
    "StreamSummary": {
      "properties": {
        "response_mode": { "const": "streaming" },
        "events_emitted": { "type": "integer", "minimum": 0 },
        "events_delivered": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "client_disconnected": { "type": "boolean" }
      },
      "required": ["response_mode", "events_emitted", "events_delivered", "duration_ms", "client_disconnected"],
      "title": "StreamSummary",
      "type": "object"
    }
  },
  "properties": {
    "invocation_id": {
      "title": "Invocation Id",
      "type": "string",
      "pattern": "^inv-[0-9a-f]{12}$"
    },
    "success": {
      "title": "Success",
      "type": "boolean"
    },
    "result": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Result"
    },
    "cost_actual": {
      "anyOf": [
        {
          "$ref": "#/$defs/CostActual"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "failure": {
      "anyOf": [
        {
          "$ref": "#/$defs/ANIPFailure"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "session": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Session"
    },
    "stream_summary": {
      "anyOf": [
        { "$ref": "#/$defs/StreamSummary" },
        { "type": "null" }
      ],
      "default": null
    },
    "client_reference_id": {
      "anyOf": [
        { "type": "string", "maxLength": 256 },
        { "type": "null" }
      ],
      "default": null,
      "title": "Client Reference Id"
    }
  },
  "required": [
    "invocation_id",
    "success"
  ],
  "title": "InvokeResponse",
  "type": "object"
}
