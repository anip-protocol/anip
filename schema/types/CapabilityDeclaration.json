{
  "$defs": {
    "CapabilityComposition": {
      "properties": {
        "capability": {
          "title": "Capability",
          "type": "string"
        },
        "optional": {
          "default": true,
          "title": "Optional",
          "type": "boolean"
        }
      },
      "required": [
        "capability"
      ],
      "title": "CapabilityComposition",
      "type": "object"
    },
    "CapabilityInput": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "type": {
          "title": "Type",
          "type": "string"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "default": {
          "default": null,
          "title": "Default"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "semantic_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Semantic Type"
        },
        "entity_reference": {
          "default": false,
          "title": "Entity Reference",
          "type": "boolean"
        },
        "allowed_values": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Allowed Values"
        },
        "catalog_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Catalog Ref"
        },
        "input_meanings": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/InputMeaning"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Input Meanings"
        },
        "resolution": {
          "anyOf": [
            {
              "$ref": "#/$defs/InputResolution"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resolution"
        }
      },
      "required": [
        "name",
        "type"
      ],
      "title": "CapabilityInput",
      "type": "object"
    },
    "CapabilityOutput": {
      "properties": {
        "type": {
          "title": "Type",
          "type": "string"
        },
        "fields": {
          "items": {
            "type": "string"
          },
          "title": "Fields",
          "type": "array"
        }
      },
      "required": [
        "type",
        "fields"
      ],
      "title": "CapabilityOutput",
      "type": "object"
    },
    "CapabilityRequirement": {
      "properties": {
        "capability": {
          "title": "Capability",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "capability",
        "reason"
      ],
      "title": "CapabilityRequirement",
      "type": "object"
    },
    "Cost": {
      "properties": {
        "certainty": {
          "$ref": "#/$defs/CostCertainty",
          "default": "fixed"
        },
        "financial": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Financial"
        },
        "determined_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Determined By"
        },
        "factors": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Factors"
        },
        "compute": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Compute"
        },
        "rate_limit": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rate Limit"
        }
      },
      "title": "Cost",
      "type": "object"
    },
    "CostCertainty": {
      "enum": [
        "fixed",
        "estimated",
        "dynamic"
      ],
      "title": "CostCertainty",
      "type": "string"
    },
    "InputMeaning": {
      "properties": {
        "label": {
          "title": "Label",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "label",
        "value"
      ],
      "title": "InputMeaning",
      "type": "object"
    },
    "InputResolution": {
      "properties": {
        "mode": {
          "enum": [
            "closed_values",
            "backend_resolved",
            "app_selected",
            "actor_policy",
            "actor_policy_or_explicit",
            "explicit_only",
            "clarify"
          ],
          "title": "Mode",
          "type": "string"
        },
        "resolver_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resolver Ref"
        },
        "on_missing": {
          "anyOf": [
            {
              "enum": [
                "clarify",
                "use_default",
                "use_actor_scope",
                "app_select_or_clarify",
                "deny",
                "deny_or_clarify",
                "omit"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "On Missing"
        },
        "on_ambiguous": {
          "anyOf": [
            {
              "enum": [
                "clarify",
                "use_default",
                "use_actor_scope",
                "app_select_or_clarify",
                "deny",
                "deny_or_clarify",
                "omit"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "On Ambiguous"
        },
        "on_unresolved": {
          "anyOf": [
            {
              "enum": [
                "clarify",
                "use_default",
                "use_actor_scope",
                "app_select_or_clarify",
                "deny",
                "deny_or_clarify",
                "omit"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "On Unresolved"
        }
      },
      "required": [
        "mode"
      ],
      "title": "InputResolution",
      "type": "object"
    },
    "ObservabilityContract": {
      "properties": {
        "logged": {
          "default": true,
          "title": "Logged",
          "type": "boolean"
        },
        "retention": {
          "default": "P90D",
          "title": "Retention",
          "type": "string"
        },
        "fields_logged": {
          "items": {
            "type": "string"
          },
          "title": "Fields Logged",
          "type": "array"
        },
        "audit_accessible_by": {
          "items": {
            "type": "string"
          },
          "title": "Audit Accessible By",
          "type": "array"
        }
      },
      "title": "ObservabilityContract",
      "type": "object"
    },
    "SessionInfo": {
      "properties": {
        "type": {
          "$ref": "#/$defs/SessionType",
          "default": "stateless"
        }
      },
      "title": "SessionInfo",
      "type": "object"
    },
    "SessionType": {
      "enum": [
        "stateless",
        "continuation",
        "workflow"
      ],
      "title": "SessionType",
      "type": "string"
    },
    "SideEffect": {
      "properties": {
        "type": {
          "$ref": "#/$defs/SideEffectType"
        },
        "rollback_window": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rollback Window"
        }
      },
      "required": [
        "type"
      ],
      "title": "SideEffect",
      "type": "object"
    },
    "SideEffectType": {
      "enum": [
        "read",
        "write",
        "irreversible",
        "transactional"
      ],
      "title": "SideEffectType",
      "type": "string"
    },
    "ResponseMode": {
      "enum": ["unary", "streaming"],
      "title": "ResponseMode",
      "type": "string"
    }
  },
  "properties": {
    "name": {
      "title": "Name",
      "type": "string"
    },
    "description": {
      "title": "Description",
      "type": "string"
    },
    "contract_version": {
      "default": "1.0",
      "title": "Contract Version",
      "type": "string"
    },
    "inputs": {
      "items": {
        "$ref": "#/$defs/CapabilityInput"
      },
      "title": "Inputs",
      "type": "array"
    },
    "output": {
      "$ref": "#/$defs/CapabilityOutput"
    },
    "side_effect": {
      "$ref": "#/$defs/SideEffect"
    },
    "minimum_scope": {
      "items": {
        "type": "string"
      },
      "title": "Minimum Scope",
      "type": "array"
    },
    "cost": {
      "anyOf": [
        {
          "$ref": "#/$defs/Cost"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "requires": {
      "items": {
        "$ref": "#/$defs/CapabilityRequirement"
      },
      "title": "Requires",
      "type": "array"
    },
    "composes_with": {
      "items": {
        "$ref": "#/$defs/CapabilityComposition"
      },
      "title": "Composes With",
      "type": "array"
    },
    "session": {
      "$ref": "#/$defs/SessionInfo"
    },
    "observability": {
      "anyOf": [
        {
          "$ref": "#/$defs/ObservabilityContract"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "response_modes": {
      "items": {
        "$ref": "#/$defs/ResponseMode"
      },
      "minItems": 1,
      "uniqueItems": true,
      "default": ["unary"],
      "title": "Response Modes",
      "type": "array"
    }
  },
  "required": [
    "name",
    "description",
    "inputs",
    "output",
    "side_effect",
    "minimum_scope"
  ],
  "title": "CapabilityDeclaration",
  "type": "object"
}
