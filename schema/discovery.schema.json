{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anip.dev/schema/v0.20/discovery.schema.json",
  "title": "ANIP Discovery Document",
  "description": "Schema for the /.well-known/anip discovery endpoint response. See SPEC.md §6.1.",
  "type": "object",
  "required": ["anip_discovery"],
  "properties": {
    "anip_discovery": {
      "type": "object",
      "required": ["protocol", "compliance", "profile", "auth", "capabilities", "endpoints"],
      "properties": {
        "protocol": {
          "type": "string",
          "pattern": "^anip/\\d+\\.\\d+$",
          "description": "ANIP protocol version (e.g., 'anip/1.0')"
        },
        "compliance": {
          "type": "string",
          "enum": ["anip-compliant", "anip-complete"],
          "description": "Compliance level — 'anip-compliant' (5 core primitives) or 'anip-complete' (all 9)"
        },
        "base_url": {
          "type": "string",
          "format": "uri",
          "description": "Base URL for resolving endpoint paths. Must be derived from the incoming request, not hardcoded."
        },
        "profile": {
          "type": "object",
          "required": ["core"],
          "properties": {
            "core": { "type": "string" },
            "cost": { "type": "string" },
            "capability_graph": { "type": "string" },
            "state_session": { "type": "string" },
            "observability": { "type": "string" }
          },
          "additionalProperties": false,
          "description": "Profile versions. 'core' is required; contextual profiles are optional."
        },
        "auth": {
          "type": "object",
          "required": ["delegation_token_required"],
          "properties": {
            "delegation_token_required": {
              "type": "boolean",
              "description": "Whether a delegation token is required for capability invocation"
            },
            "supported_formats": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Supported delegation token formats"
            },
            "minimum_scope_for_discovery": {
              "type": "string",
              "description": "Scope required to access discovery. 'none' means unauthenticated access."
            }
          }
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["description", "side_effect", "minimum_scope", "financial", "contract"],
            "properties": {
              "description": {
                "type": "string",
                "description": "What this capability does (one sentence)"
              },
              "side_effect": {
                "type": "string",
                "enum": ["read", "write", "irreversible", "transactional"],
                "description": "Side-effect type"
              },
              "minimum_scope": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Delegation scopes required (AND semantics — all must be present)"
              },
              "financial": {
                "type": "boolean",
                "description": "Whether this capability involves financial cost"
              },
              "contract": {
                "type": "string",
                "description": "Capability contract version"
              }
            }
          },
          "description": "Map of capability names to lightweight metadata summaries"
        },
        "endpoints": {
          "type": "object",
          "required": ["manifest", "permissions", "invoke", "tokens"],
          "properties": {
            "manifest": { "type": "string" },
            "handshake": { "type": "string" },
            "permissions": { "type": "string" },
            "invoke": { "type": "string" },
            "tokens": { "type": "string" },
            "graph": { "type": "string" },
            "audit": { "type": "string" },
            "test": { "type": "string" },
            "checkpoints": { "type": "string" },
            "jwks": { "type": "string" }
          },
          "description": "URL paths for standard ANIP endpoints"
        },
        "posture": {
          "type": "object",
          "properties": {
            "audit": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean", "description": "Whether audit logging is active" },
                "signed": { "type": "boolean", "description": "Whether audit entries are signed" },
                "queryable": { "type": "boolean", "description": "Whether audit log is queryable via endpoint" },
                "retention": {
                  "type": "string",
                  "description": "ISO 8601 duration for audit log retention (e.g., 'P90D')"
                },
                "retention_enforced": {
                  "type": "boolean",
                  "description": "Whether the service actively deletes expired audit entries (v0.8)"
                }
              },
              "required": ["enabled", "signed", "queryable"],
              "additionalProperties": false
            },
            "lineage": {
              "type": "object",
              "properties": {
                "invocation_id": { "type": "boolean", "description": "Whether server-generated invocation IDs are assigned" },
                "client_reference_id": {
                  "type": "object",
                  "properties": {
                    "supported": { "type": "boolean" },
                    "max_length": { "type": "integer" },
                    "opaque": { "type": "boolean", "description": "Whether client_reference_id is treated as opaque (not interpreted)" },
                    "propagation": {
                      "type": "string",
                      "enum": ["bounded", "local_only", "policy"],
                      "description": "How client_reference_id propagates"
                    }
                  },
                  "required": ["supported"],
                  "additionalProperties": false
                }
              },
              "required": ["invocation_id"],
              "additionalProperties": false
            },
            "metadata_policy": {
              "type": "object",
              "properties": {
                "bounded_lineage": { "type": "boolean", "description": "Whether lineage metadata is bounded (not unbounded transport channel)" },
                "freeform_context": { "type": "boolean", "description": "Whether arbitrary freeform context fields are accepted" },
                "downstream_propagation": {
                  "type": "string",
                  "enum": ["minimal", "policy", "service_defined"],
                  "description": "How metadata propagates downstream"
                }
              },
              "required": ["bounded_lineage"],
              "additionalProperties": false
            },
            "failure_disclosure": {
              "type": "object",
              "properties": {
                "detail_level": {
                  "type": "string",
                  "enum": ["full", "reduced", "redacted", "policy"],
                  "description": "How much error detail is surfaced to callers"
                },
                "caller_classes": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Known caller class identifiers. Informational only — does not reveal the class-to-level mapping."
                }
              },
              "required": ["detail_level"],
              "additionalProperties": false
            },
            "anchoring": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean", "description": "Whether Merkle checkpoints are active" },
                "cadence": {
                  "type": ["string", "null"],
                  "description": "ISO 8601 duration for checkpoint cadence (e.g., 'PT30S')"
                },
                "max_lag": {
                  "type": ["integer", "null"],
                  "description": "Maximum seconds between newest audit entry and latest checkpoint"
                },
                "proofs_available": { "type": "boolean", "description": "Whether inclusion/consistency proofs are available" }
              },
              "required": ["enabled"],
              "additionalProperties": false
            }
          },
          "required": ["audit", "lineage", "metadata_policy", "failure_disclosure", "anchoring"],
          "additionalProperties": false,
          "description": "Service governance posture — trust-relevant characteristics inspectable before invocation (v0.7)"
        },
        "metadata": {
          "type": "object",
          "properties": {
            "service_name": { "type": "string" },
            "service_description": { "type": "string" },
            "service_category": { "type": "string" },
            "service_tags": {
              "type": "array",
              "items": { "type": "string" }
            },
            "capability_side_effect_types_present": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["read", "write", "irreversible", "transactional"]
              },
              "description": "Informational — derivable from per-capability side_effect fields"
            },
            "max_delegation_depth": { "type": "integer" },
            "concurrent_branches_supported": { "type": "boolean" },
            "test_mode_available": { "type": "boolean" },
            "test_mode_unavailable_policy": { "type": "string" },
            "generated_at": {
              "type": "string",
              "format": "date-time"
            },
            "ttl": {
              "type": "string",
              "description": "ISO 8601 duration for caching (e.g., 'PT1H')"
            }
          },
          "description": "Service-level metadata (RECOMMENDED)"
        }
      },
      "if": {
        "properties": { "compliance": { "const": "anip-complete" } },
        "required": ["compliance"]
      },
      "then": {
        "properties": {
          "profile": {
            "required": ["core", "cost", "capability_graph", "state_session", "observability"]
          }
        }
      }
    }
  }
}
