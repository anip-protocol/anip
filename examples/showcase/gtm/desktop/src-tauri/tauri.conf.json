{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GTM Agent Desktop",
  "version": "0.1.0",
  "identifier": "dev.anip.gtm-agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GTM Agent Desktop",
        "width": 1280,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#101820"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Business",
    "icon": [
      "../../../../../studio/src-tauri/icons/32x32.png",
      "../../../../../studio/src-tauri/icons/128x128.png",
      "../../../../../studio/src-tauri/icons/128x128@2x.png",
      "../../../../../studio/src-tauri/icons/icon.icns",
      "../../../../../studio/src-tauri/icons/icon.ico"
    ],
    "shortDescription": "Installable GTM Agent showcase for ANIP",
    "longDescription": "A local GTM Agent demo that runs governed ANIP services without Docker."
  }
}
