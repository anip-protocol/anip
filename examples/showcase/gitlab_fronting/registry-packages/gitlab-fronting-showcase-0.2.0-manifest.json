    "generate_from_registry": "go run ./cmd/anip-generate --registry-url \u003cregistry-url\u003e --package-id gitlab-fronting-showcase --package-version 0.2.0 --target python --dependency-source registry --output ./generated/gitlab-fronting-showcase --force",
