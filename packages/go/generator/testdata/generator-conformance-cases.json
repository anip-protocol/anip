            "contains": [
              "def _requires_governed_stop(capability: dict[str, Any]) -> bool:",
              "approval = next((binding for binding in matching if binding.get('decision') == 'approval_required'), None)",
              "allowed = next((binding for binding in matching if binding.get('decision') not in {'deny', 'clarify', 'approval_required'}), None)",
              "No matching runtime policy binding; continuing."
            ]
          }
        ],
        "typescript": [
          {
            "path": "src/runtime/policy.ts",
            "contains": [
              "function requiresGovernedStop(capability: GeneratedCapabilityRuntimeMetadata): boolean",
              "const approval = matching.find((binding) => binding.decision === \"approval_required\");",
              "const allowed = matching.find((binding) => binding.decision !== \"deny\" && binding.decision !== \"clarify\" && binding.decision !== \"approval_required\");",
              "No matching runtime policy binding; continuing."
            ]
          }
        ],
        "go": [
          {
            "path": "extensions/policy.go",
            "contains": [
