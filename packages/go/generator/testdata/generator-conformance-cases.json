        "\"conformance.lookup\"",
        "\"conformance.prepare_change\"",
        "\"conformance.lookup_and_prepare\"",
        "\"grant_policy\": {",
        "\"policy_bindings\": [",
        "\"decision\": \"allow_with_limits\"",
        "\"decision\": \"deny\"",
        "\"decision\": \"approval_required\"",
        "\"resolution\": {",
        "\"mode\": \"backend_resolved\"",
        "\"resolver_ref\": \"conformance.record_catalog\"",
        "\"mode\": \"closed_values\"",
        "\"catalog_ref\": \"conformance.status_catalog\"",
        "\"child_approval_required\": \"propagate\"",
        "\"backend_input_mode\": \"hybrid\"",
        "\"explicit_required_backend_inputs\": ["
      ]
    },
    {
      "id": "generated-host-uses-filtered-adapter-input",
      "description": "Generated hosts must build adapter_input from semantic plus backend-contract keys and must not forward arbitrary request parameters.",
      "target_markers": {
        "python": [
          {
            "path": "src/generator_conformance_service/capabilities.py",
            "contains": [
              "adapter_keys = semantic_keys | set(contract[\"required\"]) | set(contract[\"optional\"])",
              "adapter_input = {key: value for key, value in params.items() if key in adapter_keys}",
              "backend_adapter.execute(capability, plan, plan[\"adapter_input\"]"
            ]
          }
        ],
        "typescript": [
          {
            "path": "src/generated/capabilities.ts",
            "contains": [
              "const adapterKeys = new Set([...semanticKeys, ...backendInputContract.required, ...backendInputContract.optional]);",
              "const adapterInput = Object.fromEntries(Object.entries(params).filter(([key]) => adapterKeys.has(key)));",
              "backendAdapter.execute(capability, plan, plan.adapter_input"
            ]
          }
        ],
        "go": [
          {
            "path": "host/capabilities.go",
            "contains": [
              "adapterKeys := map[string]struct{}{}",
              "if _, ok := adapterKeys[key]; ok {",
              "BackendAdapterInstance.Execute(capability, plan, plan.AdapterInput"
            ]
          }
        ],
        "java": [
          {
            "path": "src/main/java/dev/anip/generated/generator_conformance_service/GeneratedCapabilities.java",
            "contains": [
              "Set<String> adapterKeys = new LinkedHashSet<>(semanticKeys);",
              "if (adapterKeys.contains(entry.getKey())) {",
              "backendAdapter.execute(capability, plan, objectMap(plan.get(\"adapter_input\")), ctx)"
            ]
          }
        ],
        "csharp": [
          {
            "path": "GeneratedCapabilities.cs",
            "contains": [
              "var adapterKeys = new HashSet<string>(semanticKeys);",
              "if (adapterKeys.Contains(entry.Key))",
              "backendAdapter(capability, plan, (Dictionary<string, object?>)plan[\"adapter_input\"]!, ctx)"
            ]
          }
        ]
      }
    },
    {
      "id": "generated-policy-precedence-is-consistent",
      "description": "Every target must implement the same sparse policy override semantics and governed-stop precedence.",
      "target_markers": {
        "python": [
