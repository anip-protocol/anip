<Project>
  <PropertyGroup>
    <Authors>ANIP Protocol</Authors>
    <Company>ANIP Protocol</Company>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageProjectUrl>https://anip.dev</PackageProjectUrl>
    <RepositoryUrl>https://github.com/anip-protocol/anip</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>anip;agent;protocol;delegation;trust</PackageTags>
    <Description>ANIP — Agent-Native Interface Protocol</Description>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <!-- Version is set at pack time via /p:Version -->
</Project>
