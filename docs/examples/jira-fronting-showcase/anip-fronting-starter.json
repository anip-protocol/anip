      "capability_id": "jira.backlog.search_context",
      "title": "Search Backlog Context",
      "summary": "Find bounded work context in an allowed Jira project without exposing raw JQL or unbounded issue export.",
      "subject_kind": "jira_project",
      "context_type": "backlog_context_search",
      "output_intent": "bounded_issue_context",
      "backend_kind": "native_api",
      "connection_ref": "jira_fronting",
      "path": "/jira/backlog/context/search",
      "raw_operation_refs": [
        "jira.rest.search_issues"
      ],
      "side_effect_level": "read",
      "backend_input_mode": "explicit",
      "inputs": [
        {
          "name": "project_key",
          "type": "string",
          "required": true,
          "summary": "Allowed Jira project key.",
          "semantic_type": "project_scope",
          "entity_reference": true,
          "catalog_ref": "jira.project_catalog",
          "resolution": {
            "mode": "backend_resolved",
            "resolver_ref": "jira.project_catalog",
            "on_missing": "clarify",
            "on_ambiguous": "clarify",
            "on_unresolved": "clarify"
          },
          "clarification_hint": "Ask which Jira project should be searched."
        },
        {
          "name": "query",
          "type": "string",
          "required": true,
          "summary": "Bounded work-search intent. The service owns safe JQL construction.",
          "semantic_type": "search_query",
          "resolution": {
            "mode": "explicit_only",
            "on_missing": "clarify",
            "on_ambiguous": "clarify",
            "on_unresolved": "clarify"
          },
          "clarification_hint": "Ask what work context the user wants to find."
        },
        {
          "name": "issue_type",
          "type": "string",
          "required": false,
          "summary": "Optional issue type filter.",
          "allowed_values": [
            "bug",
            "story",
            "task",
            "epic"
          ],
          "resolution": {
            "mode": "closed_values",
            "on_missing": "omit",
            "on_unresolved": "deny"
          }
        },
        {
          "name": "status",
          "type": "string",
          "required": false,
          "summary": "Optional workflow status filter resolved by the backend.",
          "semantic_type": "workflow_status",
          "catalog_ref": "jira.workflow_status_catalog",
          "resolution": {
            "mode": "backend_resolved",
            "resolver_ref": "jira.workflow_status_catalog",
            "on_missing": "omit",
            "on_ambiguous": "clarify",
            "on_unresolved": "clarify"
          }
        },
        {
          "name": "limit",
          "type": "integer",
          "required": false,
          "summary": "Maximum issues to return.",
          "default_value": "25",
          "resolution": {
            "mode": "clarify",
            "on_missing": "use_default"
          }
        },
        {
          "name": "backend_options",
          "type": "object",
          "required": false,
          "summary": "Bounded Jira provider options such as selected fields, pagination, or safe expand clauses. Must not allow arbitrary JQL or raw export.",
          "semantic_type": "backend_options",
          "resolution": {
            "mode": "explicit_only",
            "on_missing": "omit"
          },
          "clarification_hint": "Do not ask for backend_options unless the user explicitly needs provider-specific controls."
        }
      ]
    },
